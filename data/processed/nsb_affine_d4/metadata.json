{
  "experiment": {
    "name": "nsb_affine_d4",
    "problem": "navier_stokes_brinkman",
    "coefficient": "affine",
    "dimension": 4,
    "targets": [
      "u",
      "p"
    ]
  },
  "grid": {
    "shape": [
      16,
      16
    ]
  },
  "pde": {
    "equation": "navier_stokes_brinkman",
    "boundary_conditions": {
      "type": "paper_like"
    },
    "viscosity": {
      "parametrized": true
    },
    "pressure_normalization": "zero_mean"
  },
  "coefficient": {
    "name": "affine",
    "base_value": 2.62,
    "formula": "2.62 + sum_j x_j sin(pi z_1 j) / j^(3/2)"
  },
  "data": {
    "train_sizes": [
      10,
      20,
      50,
      100,
      200,
      500
    ],
    "test_size": 500,
    "seeds": [
      0,
      1,
      2
    ],
    "dtype": "float32"
  },
  "output": {
    "output_dimensions": {
      "y_u": 512,
      "y_p": 256
    }
  },
  "note": "Simplified stabilized finite-difference Brinkman dataset. This is not the exact mixed FEM NSB solver from the target paper."
}